manifest {
  name = 'ngs_variant_calling_nextflow'
  version = '3.0.0'
  nextflowVersion = '>=25.10.4'
}

params {
  help = false
  image = 'leonardliu0910/wgs_variant_calling:latest'
  sif = null

  input_dir = null
  input_vcf = null
  SRA_list = null
  trimmed_input_dir = null
  ref = null
  read_type = 'PE'
  caller = 'bcftools'
  use_bqsr = false
  cleanup_GVCFS = true
  // Skip Raw FastQC + Raw MultiQC. Trimmed FastQC still runs.
  // Raw FastQC is mainly useful as a quality-decision step; production reruns can skip it.
  skip_raw_fastqc = false
  interval_size = null
  run_step = 'all'
  fastp_parameters = ''
  bwamem2_parameters = ''
  bcftools_mpileup_parameters = ''
  bcftools_call_parameters = ''
  bcftools_concat_parameters = ''
  gatk_haplotypecaller_parameters = ''
  gatk_genomicsdbimport_parameters = ''
  // GenomicsDBImport batch size. 1 disables batch IO optimization; GATK recommends
  // 50 for small cohorts and 200+ for large cohorts. Tune up for cohorts > ~200 samples.
  gatk_genomicsdbimport_batch_size = 50
  // When true, run GenomicsDBImport with --consolidate. Recommended for large cohorts
  // to speed up downstream GenotypeGVCFs; adds extra import-time cost.
  gatk_genomicsdbimport_consolidate = false
  gatk_genotypegvcfs_parameters = ''
  gatk_baserecalibrator_parameters = ''
  gatk_applybqsr_parameters = ''
  gatk_variantfiltration_snp_parameters = ''
  gatk_variantfiltration_indel_parameters = ''
  publish_cram = true

  // --- VCF post-calling filtering (Step5) ---
  // Default off so the main calling pipeline stays simple unless the user explicitly asks for post-calling filtering.
  enable_vcffilter = false
  // Default to final so the workflow runs phase1 review plus phase2 final filtering unless the user explicitly stops after phase1.
  vcffilter_stop_after = 'final'

  // phase1
  // Default off because mislabeled-sample removal is project-specific and should never happen silently.
  phase1_remove_mislabeled = false
  // No default file because this input depends on cohort-specific QC evidence.
  phase1_mislabeled_samples = null
  // GQ 20 is a common conservative starting point for masking low-confidence genotypes.
  phase1_min_gq = 20
  // DP 5 removes very weak genotype calls while keeping moderate-coverage data usable.
  phase1_min_dp = 5
  // Allelic-balance masking is enabled because heterozygote imbalance is a common SNP noise pattern.
  phase1_enable_ab_mask = true
  // Use half of the sample mean DP as the lower cutoff to suppress unusually shallow genotypes.
  phase1_sample_dp_min_factor = 0.5
  // Use 2.5x the sample mean DP as the upper cutoff to suppress suspiciously deep genotypes.
  phase1_sample_dp_max_factor = 2.5
  // These cutoffs give quick visual anchors for strict, moderate, and permissive sample filtering choices.
  phase1_sample_missing_plot_cutoffs_pct = '5,10,20,40'

  // phase2
  // Removing highly incomplete samples before final site filtering usually improves final callset quality.
  phase2_remove_high_missing_samples = true
  // No default manual removal list because this is cohort-specific user input.
  phase2_high_missing_sample_file = null
  // Left unset by default so the user decides the missingness cutoff for the current dataset.
  phase2_max_sample_missing = null
  // QUAL 30 is a standard moderate-confidence site threshold for final SNP filtering.
  phase2_min_qual = 30
  // Site missingness 0.2 keeps sites callable in most samples while removing heavily incomplete loci.
  phase2_max_site_missing = 0.2
  // Enabled because mean site DP extremes are useful for removing shallow or excessively deep loci.
  phase2_enable_site_mean_dp_filter = true
  // Lower mean-site-DP factor mirrors the sample-level DP logic and removes unusually low-depth loci.
  phase2_site_mean_dp_min_factor = 0.5
  // Upper mean-site-DP factor helps exclude overly deep loci linked to repeats or mapping artifacts.
  phase2_site_mean_dp_max_factor = 2.5
  // Reuse the same cutoffs so final sample-missingness plots are easy to compare with earlier review plots.
  phase2_sample_missing_plot_cutoffs_pct = '5,10,20,40'
}

process {
  // Retry transient failures (node flake, IO blips, OOM) up to 3 times, then
  // let already-running tasks drain via 'finish' so other branches still
  // produce output instead of the whole run being killed.
  errorStrategy = { task.attempt <= 3 ? 'retry' : 'finish' }
  maxRetries = 3
  shell = ['/bin/bash', '-euo', 'pipefail']

  // Base fallback used only when a profile does not define its own process.cpus.
  // In normal use, local/slurm/awsbatch profiles below should provide the real defaults.
  // Individual tools use task.cpus, so the value that matters is the one resolved here.
  cpus = 1
}

docker {
  enabled = false
}

singularity {
  enabled = false
  autoMounts = true
}

apptainer {
  enabled = true
  autoMounts = true
}

profiles {
  local {
    process {
      executor = 'local'

      // Global default for local runs.
      // If a process does NOT have a dedicated withName override, it will inherit this cpu value.
      // Change this when you want all local tasks to use a different default thread count.
      cpus = 4

      // Local per-process override templates.
      // Uncomment one block and set a concrete cpu value only when that process
      // should differ from the global local cpu default above.

      // Step1 Raw_QC
      // withName: 'FASTQC_RAW_PROCESS'               { cpus = 8 }
      // withName: 'MULTIQC_RAW_PROCESS'              { cpus = 8 }
      // withName: 'FASTERQ_DUMP_SE_PROCESS'          { cpus = 8 }
      // withName: 'FASTERQ_DUMP_PE_PROCESS'          { cpus = 8 }

      // Step2 Trimming_QC
      // withName: 'FASTP_SE_PROCESS'                 { cpus = 8 }
      // withName: 'FASTP_PE_PROCESS'                 { cpus = 8 }
      // withName: 'FASTQC_POST_PROCESS'              { cpus = 8 }
      // withName: 'MULTIQC_POST_PROCESS'             { cpus = 8 }

      // Step3 Aligning
      // withName: 'BWAMEM2_INDEX_PROCESS'            { cpus = 8 }
      // withName: 'ALIGN_MARKDUP_SE_PROCESS'         { cpus = 16 }
      // withName: 'ALIGN_MARKDUP_PE_PROCESS'         { cpus = 16 }

      // Step4 Calling
      // withName: 'BCFTOOLS_CALL_BY_CHR_PROCESS'     { cpus = 8 }
      // withName: 'BCFTOOLS_MERGE_PROCESS'           { cpus = 8 }
      // withName: 'GATK_BQSR_PROCESS'                { cpus = 4 }
      // withName: 'GATK_HAPLOTYPECALLER_BY_CHR_PROCESS' { cpus = 4 }
      // withName: 'GATK_GENOMICSDBIMPORT_BY_CHR_PROCESS' { cpus = 2 }
      // withName: 'GATK_CLEANUP_GVCF_PROCESS'        { cpus = 8 }
      // withName: 'GATK_GENOTYPEGVCFS_BY_CHR_PROCESS' { cpus = 2 }
      // withName: 'GATK_MERGE_RAW_PROCESS'           { cpus = 8 }
      // withName: 'GATK_FILTER_PROCESS'              { cpus = 8 }

      // Step5 VCF_Filtering
      // withName: 'PHASE2_INITIAL_SAMPLE_MISSINGNESS_PROCESS' { cpus = 8 }
      // withName: 'PHASE2_REMOVE_HIGH_MISSING_SAMPLES_PROCESS' { cpus = 8 }
      // withName: 'PHASE2_SITE_MEAN_DP_LIMITS_PROCESS' { cpus = 8 }
      // withName: 'PHASE2_FINAL_FILTER_PROCESS'      { cpus = 8 }
      // withName: 'PHASE2_FINAL_REPORTS_PROCESS'     { cpus = 8 }
    }
    workDir = 'work'
  }

  slurm {
    process {
      executor = 'slurm'

      // Global SLURM defaults.
      // These are the default resources used by every process in the slurm profile
      // unless that process has its own withName block below.
      //
      // How to modify resources:
      // 1. If you want to change the default resources for most steps, edit these global values.
      // 2. If you want to change only one specific step, leave these global values as they are
      //    and edit that step's withName block below instead.
      //
      // Precedence:
      // withName block for a specific process > global process settings in this profile > top-level process fallback
      //
      // Common usage:
      // - If you want ONE global setting for almost everything, edit only these global values.
      //   Because the withName blocks below are null by default, they will not override the global defaults.
      // - If one process needs special resources, set concrete values only in that process's withName block.
      queue = 'bdw'
      cpus = 2
      memory = 20.GB
      time = 24.h

      // Optional cluster-wide sbatch flags applied to all SLURM jobs in this profile.
      // Use this for account / qos / constraint settings that should affect the whole pipeline.
      // Example:
      // clusterOptions = '--account=my_account --qos=normal --constraint=cpu'
      clusterOptions = '--account=gratis --nodes=1'



      // Per-process SLURM overrides grouped by workflow step.
      // Each withName block targets one Nextflow process by its exact process name.
      // Use these blocks when one step needs different queue / cpu / memory / time than the global defaults above.
      //
      // Important:
      // - Do NOT use null here to mean "inherit global".
      //   In practice that can unset the resource and let the executor fall back to
      //   scheduler defaults instead of the global values above.
      // - To inherit the global setting, keep the template commented out.
      // - Only uncomment a block when this process truly needs a process-specific override.
      //
      // Example:
      // - Global:
      //     queue = 'normal.168h'
      //     cpus = 4
      //     memory = 16.GB
      //     time = 24.h
      // - If only BWAMEM2_INDEX_PROCESS needs more memory, uncomment only:
      //     withName: 'BWAMEM2_INDEX_PROCESS' {
      //       memory = 80.GB
      //       time   = 8.h
      //     }
      //   Then BWAMEM2_INDEX_PROCESS will use global queue/cpus, but its own memory/time.
      //

      // Step1 Raw_QC and SRA download
      // withName: 'FASTQC_RAW_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 4
      //   memory = 8.GB
      //   time   = 24.h
      // }
      // withName: 'MULTIQC_RAW_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 4
      //   memory = 8.GB
      //   time   = 24.h
      // }
      // withName: 'FASTERQ_DUMP_SE_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 4
      //   memory = 8.GB
      //   time   = 24.h
      // }
      // withName: 'FASTERQ_DUMP_PE_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 4
      //   memory = 8.GB
      //   time   = 24.h
      // }

      // Step2 Trimming_QC
      // withName: 'FASTP_SE_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 8
      //   memory = 8.GB
      //   time   = 24.h
      // }
      // withName: 'FASTP_PE_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 8
      //   memory = 8.GB
      //   time   = 24.h
      // }
      // withName: 'FASTQC_POST_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 4
      //   memory = 8.GB
      //   time   = 24.h
      // }
      // withName: 'MULTIQC_POST_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 4
      //   memory = 8.GB
      //   time   = 24.h
      // }

      // Step3 Aligning
      // withName: 'BWAMEM2_INDEX_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 4
      //   memory = 8.GB
      //   time   = 24.h
      // }
      // withName: 'ALIGN_MARKDUP_SE_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 16
      //   memory = 32.GB
      //   time   = 24.h
      // }
      // withName: 'ALIGN_MARKDUP_PE_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 16
      //   memory = 32.GB
      //   time   = 24.h
      // }

      // Step4 Calling
      // withName: 'BCFTOOLS_CALL_BY_CHR_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 8
      //   memory = 16.GB
      //   time   = 24.h
      // }
      // withName: 'BCFTOOLS_MERGE_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 4
      //   memory = 8.GB
      //   time   = 24.h
      // }
      // withName: 'GATK_BQSR_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 4
      //   memory = 16.GB
      //   time   = 24.h
      // }
      // withName: 'GATK_HAPLOTYPECALLER_BY_CHR_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 4
      //   memory = 16.GB
      //   time   = 24.h
      // }
      // withName: 'GATK_GENOMICSDBIMPORT_BY_CHR_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 2
      //   memory = 32.GB
      //   time   = 24.h
      // }
      // withName: 'GATK_CLEANUP_GVCF_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 4
      //   memory = 8.GB
      //   time   = 24.h
      // }
      // withName: 'GATK_GENOTYPEGVCFS_BY_CHR_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 2
      //   memory = 16.GB
      //   time   = 24.h
      // }
      // withName: 'GATK_MERGE_RAW_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 4
      //   memory = 8.GB
      //   time   = 24.h
      // }
      // withName: 'GATK_FILTER_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 4
      //   memory = 8.GB
      //   time   = 24.h
      // }

      // Step5 VCF_Filtering
      // withName: 'PHASE2_INITIAL_SAMPLE_MISSINGNESS_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 4
      //   memory = 8.GB
      //   time   = 24.h
      // }
      // withName: 'PHASE2_REMOVE_HIGH_MISSING_SAMPLES_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 4
      //   memory = 8.GB
      //   time   = 24.h
      // }
      // withName: 'PHASE2_SITE_MEAN_DP_LIMITS_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 4
      //   memory = 8.GB
      //   time   = 24.h
      // }
      // withName: 'PHASE2_FINAL_FILTER_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 4
      //   memory = 8.GB
      //   time   = 24.h
      // }
      // withName: 'PHASE2_FINAL_REPORTS_PROCESS' {
      //   queue  = 'normal.168h'
      //   cpus   = 4
      //   memory = 8.GB
      //   time   = 24.h
      // }
    }

    // Limit how many SLURM jobs Nextflow keeps in the submit queue at the same time.
    // Default 50 is reasonable for medium cohorts; raise (e.g. 200-500) for large
    // cohorts subject to your cluster fair-share / MaxJobs policy.
    executor.queueSize = 50
    // Throttle sbatch submissions to avoid bursting the controller.
    executor.submitRateLimit = '50/sec'
    workDir = 'work'
  }

  awsbatch {
    process {
      executor = 'awsbatch'

      // Global AWS Batch defaults.
      // These work the same way as the SLURM global defaults above:
      // every process will inherit these values unless you later add process-specific overrides.
      //
      // Before using this profile, set:
      // - queue: your AWS Batch queue name
      // - container: your Docker image
      // - cpus/memory: the default resources for most jobs
      queue = 'CHANGE_ME_AWS_BATCH_QUEUE'
      cpus = 4
      memory = 16.GB
      container = 'CHANGE_ME_DOCKER_IMAGE'

      // Per-process AWS Batch overrides grouped by workflow step.
      // Omit a withName block entirely when a process should inherit the global AWS Batch defaults above.
    }

    docker.enabled = true
    apptainer.enabled = false
    singularity.enabled = false

    // Additional AWS Batch settings.
    // Edit these directly here instead of passing them on the command line.
    aws.region = 'us-east-1'
    // aws.batch.cliPath = '/path/to/aws'

    // S3 work directory used by Nextflow for AWS Batch execution.
    // Change this to a bucket/path you control before running the awsbatch profile.
    workDir = 's3://CHANGE_ME_NF_WORKDIR/work'
  }
}

timeline {
  enabled = true
  file = 'pipeline_info/timeline.html'
  overwrite = true
}

report {
  enabled = true
  file = 'pipeline_info/report.html'
  overwrite = true
}

trace {
  enabled = true
  file = 'pipeline_info/trace.txt'
  overwrite = true
}

dag {
  enabled = true
  file = 'pipeline_info/dag.html'
  overwrite = true
}
