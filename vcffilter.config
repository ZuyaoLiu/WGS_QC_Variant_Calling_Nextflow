params {
  enable_vcffilter = false
  // Default off so the main calling pipeline stays simple unless the user explicitly asks for post-calling filtering.

  vcffilter_stop_after = 'final'
  // Default to final so the workflow runs phase1 review plus phase2 final filtering unless the user explicitly stops after phase1.

  // phase1
  phase1_remove_mislabeled = false
  // Default off because mislabeled-sample removal is project-specific and should never happen silently.

  phase1_mislabeled_samples = null
  // No default file because this input depends on cohort-specific QC evidence.

  phase1_min_gq = 20
  // GQ 20 is a common conservative starting point for masking low-confidence genotypes.

  phase1_min_dp = 5
  // DP 5 removes very weak genotype calls while keeping moderate-coverage data usable.

  phase1_enable_ab_mask = true
  // Allelic-balance masking is enabled because heterozygote imbalance is a common SNP noise pattern.

  phase1_sample_dp_min_factor = 0.5
  // Use half of the sample mean DP as the lower cutoff to suppress unusually shallow genotypes.

  phase1_sample_dp_max_factor = 2.5
  // Use 2.5x the sample mean DP as the upper cutoff to suppress suspiciously deep genotypes.

  phase1_sample_missing_plot_cutoffs_pct = '5,10,20,40'
  // These cutoffs give quick visual anchors for strict, moderate, and permissive sample filtering choices.

  // phase2
  phase2_remove_high_missing_samples = true
  // Removing highly incomplete samples before final site filtering usually improves final callset quality.

  phase2_high_missing_sample_file = null
  // No default manual removal list because this is cohort-specific user input.

  phase2_max_sample_missing = null
  // Left unset by default so the user decides the missingness cutoff for the current dataset.

  phase2_min_qual = 30
  // QUAL 30 is a standard moderate-confidence site threshold for final SNP filtering.

  phase2_max_site_missing = 0.2
  // Site missingness 0.2 keeps sites callable in most samples while removing heavily incomplete loci.

  phase2_enable_site_mean_dp_filter = true
  // Enabled because mean site DP extremes are useful for removing shallow or excessively deep loci.

  phase2_site_mean_dp_min_factor = 0.5
  // Lower mean-site-DP factor mirrors the sample-level DP logic and removes unusually low-depth loci.

  phase2_site_mean_dp_max_factor = 2.5
  // Upper mean-site-DP factor helps exclude overly deep loci linked to repeats or mapping artifacts.

  phase2_sample_missing_plot_cutoffs_pct = '5,10,20,40'
  // Reuse the same cutoffs so final sample-missingness plots are easy to compare with earlier review plots.
}
